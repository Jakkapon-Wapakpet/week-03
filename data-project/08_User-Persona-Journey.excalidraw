        "group_persona_2"
      ],
      "frameId": null,
      "roundness": null,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783497835400,
      "link": null,
      "locked": false,
      "text": "• อายุ: 28 ปี (Software Engineer / รายได้สูง)\n• พฤติกรรม: ชื่นชอบการโมดิฟายด์และสะสม Custom Keyboards\n• ความต้องการ: สเปกขั้นสูง เช่น บอดี้อะลูมิเนียม CNC, เชื่อมต่อไร้สาย 3 โหมด",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• อายุ: 28 ปี (Software Engineer / รายได้สูง)\n• พฤติกรรม: ชื่นชอบการโมดิฟายด์และสะสม Custom Keyboards\n• ความต้องการ: สเปกขั้นสูง เช่น บอดี้อะลูมิเนียม CNC, เชื่อมต่อไร้สาย 3 โหมด",
      "lineHeight": 1.2,
      "version": 2,
      "versionNonce": 1407024408,
      "index": "b1W",
      "angle": 0,
      "seed": 1,
      "autoResize": true
    },
